#!/usr/bin/env bash
set -euo pipefail

APP=Tcrypt
MAIN=tcrypt.crypto.Tcrypt

ROOT="$(cd "$(dirname "$0")" && pwd)"

OUT="$ROOT/out"
JAR="$ROOT/tcrypt.jar"

BUILD="$ROOT/build-appimage"
APPDIR="$BUILD/AppDir"

echo "[1/7] Cleaning..."
rm -rf "$BUILD"
mkdir -p "$APPDIR"

echo "[2/7] Compiling..."

rm -rf "$OUT"
mkdir -p "$OUT"

javac \
    -d "$OUT" \
    $(find "$ROOT/src" -name '*.java')

echo "[3/7] Creating jar..."

rm -f "$JAR"

jar \
    --create \
    --file "$JAR" \
    --main-class "$MAIN" \
    -C "$OUT" .

echo "[4/7] Creating runtime..."

jdeps \
    --print-module-deps \
    "$JAR" \
    > "$BUILD/modules.txt"

MODULES="$(cat "$BUILD/modules.txt")"

if [[ "$MODULES" != *java.desktop* ]]; then
    MODULES="$MODULES,java.desktop"
fi

jlink \
    --add-modules "$MODULES" \
    --strip-debug \
    --compress=2 \
    --no-header-files \
    --no-man-pages \
    --output "$APPDIR/usr"

echo "[5/7] Copying jar..."

cp "$JAR" "$APPDIR/usr/"

echo "[6/7] Creating launcher..."

cat > "$APPDIR/AppRun" <<EOF
#!/bin/sh

HERE=\$(dirname "\$(readlink -f "\$0")")

exec "\$HERE/usr/bin/java" \
    -jar "\$HERE/usr/tcrypt.jar"
EOF

chmod +x "$APPDIR/AppRun"

cat > "$APPDIR/Tcrypt.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Tcrypt
Exec=Tcrypt
Icon=Tcrypt
Categories=Utility;
EOF

echo "[7/7] Creating icon..."

# placeholder icon
touch "$APPDIR/Tcrypt.png"

cd "$BUILD"

appimagetool AppDir

mv ./*.AppImage "$ROOT"

echo
echo "Done:"
ls -lh "$ROOT"/*.AppImage
